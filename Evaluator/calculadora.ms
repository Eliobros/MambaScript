escreva "=== CALCULADORA ==="
escreva "Digite o primeiro número:"
variavel a = ler()

escreva "Digite o segundo número:"
variavel b = ler()

variavel soma = a + b
variavel sub = a - b
variavel mult = a * b
variavel div = a / b

escreva ""
escreva "Soma: " + soma
escreva "Subtração: " + sub
escreva "Multiplicação: " + mult
escreva "Divisão: " + div
